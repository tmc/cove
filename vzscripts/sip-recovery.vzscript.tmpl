# Auto-generated vzscript for SIP {{.Mode}} in recovery mode
# Generated by: cove sip {{.Mode}}-auto

wait 20s
startup-options 180s
recovery-continue 240s
wait-menu-text Utilities 180s
key cmd+shift+t
ocr-wait '-bash-3.2#' 60s
key cmd+k
wait 500ms
ocr-wait '-bash-3.2#' 30s
type-keycodes {{.CSRUtilCommand}}
key return
wait 2s
{{ if .Confirm }}
[text-visible:Are+you+sure] type-keycodes 'y'
[text-visible:Are+you+sure] key return
[text-visible:Are+you+sure] wait-prompt-clear 'Are you sure' 20s
[text-visible:%5By%2Fn%5D] type-keycodes 'y'
[text-visible:%5By%2Fn%5D] key return
[text-visible:%5By%2Fn%5D] wait-prompt-clear '[y/n]' 20s
wait 1s
{{ end }}
{{ if .Username }}
[text-visible:Authorized+user] type-keycodes {{.Username}}
[text-visible:Authorized+user] key return
[text-visible:Authorized+user] wait-prompt-clear 'Authorized user' 20s
[text-visible:Enter+username] type-keycodes {{.Username}}
[text-visible:Enter+username] key return
[text-visible:Enter+username] wait-prompt-clear 'Enter username' 5s
[text-visible:user+name] type-keycodes {{.Username}}
[text-visible:user+name] key return
[text-visible:user+name] wait-prompt-clear 'user name' 5s
wait 1s
{{ end }}
{{ if .Password }}
[text-visible:Password] type-keycodes {{.Password}}
[text-visible:Password] key return
[text-visible:Password] wait-prompt-clear 'Password' 20s
[text-visible:Enter+password] type-keycodes {{.Password}}
[text-visible:Enter+password] key return
[text-visible:Enter+password] wait-prompt-clear 'Enter password' 5s
[text-visible:password+for+user] type-keycodes {{.Password}}
[text-visible:password+for+user] key return
[text-visible:password+for+user] wait-prompt-clear 'password for user' 20s
wait 10s
{{ end }}
[text-visible:{{.SuccessTextCondition}}] screenshot
{{ if .Reboot }}
type-keycodes 'reboot'
key return
wait 2s
{{ end }}
