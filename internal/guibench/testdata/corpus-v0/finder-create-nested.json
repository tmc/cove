{
  "id": "finder-create-nested",
  "image": "macos-base:v1",
  "domain": "Finder",
  "instruction": "In Finder, create the nested folders ~/Desktop/{PARENT}/{CHILD}.",
  "source": "cove-original (design 047 §9 slice 4); Tier-A file_exists on the nested directory",
  "complexity": 2,
  "schema": [
    {"name": "PARENT", "pool": ["Work", "Personal", "Clients"]},
    {"name": "CHILD", "pool": ["2025", "Inbox", "Done"]}
  ],
  "config": [
    {"args": ["sh", "-c", "rm -rf \"$HOME/Desktop/{PARENT}\""]}
  ],
  "solution": [
    {"args": ["sh", "-c", "mkdir -p \"$HOME/Desktop/{PARENT}/{CHILD}\""]}
  ],
  "evaluator": {
    "func": "file_exists",
    "result": {
      "kind": "exec",
      "args": ["sh", "-c", "test -d \"$HOME/Desktop/{PARENT}/{CHILD}\" && echo true || echo false"]
    }
  }
}
