{
  "id": "finder-create-folder",
  "image": "macos-base:v1",
  "instruction": "Using Finder, create a new folder named {FOLDER} on the Desktop.",
  "source": "guibench example corpus (design 047 §9 slice 7); Tier-A demonstration task",
  "complexity": 2,
  "schema": [
    {"name": "FOLDER", "pool": ["Project", "Invoices", "Photos", "Drafts"]}
  ],
  "config": [
    {"args": ["sh", "-c", "rm -rf \"$HOME/Desktop/{FOLDER}\""]}
  ],
  "evaluator": {
    "func": "file_exists",
    "result": {
      "kind": "exec",
      "args": ["sh", "-c", "test -d \"$HOME/Desktop/{FOLDER}\" && echo true || echo false"]
    }
  }
}
