# Auto-generated vzscript for SIP {{.Mode}} in recovery mode
# Generated by: cove sip {{.Mode}}-auto

label-push 'SIP {{.Mode}}'
wait 20s
label-push 'Recovery picker'
recovery-options 180s
recovery-continue 240s
wait-menu-text Utilities 180s
label-pop
label-push 'Recovery Terminal'
key cmd+shift+t
ocr-wait '-bash-3.2#' 60s
key cmd+k
wait 500ms
type-keycodes {{.CSRUtilCommand}}
key return
wait 2s
label-pop
label-push 'csrutil prompts'
{{ if .Confirm }}
answer-visible -timeout 45s -progress 'Authorized user' -progress 'Enter username' -progress 'user name' -progress 'Password' -progress 'Enter password' -progress 'password for user' -progress {{.SuccessText}} 'y/n' 'y' 'Are you sure' 'y' 'security level to full boot security' 'y'
wait 1s
{{ end }}
{{ if .Username }}
answer-visible -optional -timeout 5s -progress 'Password' -progress 'Enter password' -progress 'password for user' -progress {{.SuccessText}} 'Authorized user' {{.Username}} 'Enter username' {{.Username}} 'user name' {{.Username}}
wait 1s
{{ end }}
{{ if .Password }}
answer-visible -timeout 45s -progress {{.SuccessText}} -progress '-bash-3.2#' 'Password' {{.Password}} 'Enter password' {{.Password}} 'password for user' {{.Password}}
wait 2s
{{ end }}
ocr-wait {{.SuccessText}} 60s
[text-visible:{{.SuccessTextCondition}}] screenshot
label-pop
{{ if .Reboot }}
label-push 'Reboot'
[text-visible:{{.SuccessTextCondition}}] type-keycodes 'reboot'
[text-visible:{{.SuccessTextCondition}}] key return
wait 2s
label-pop
{{ end }}
label-pop
