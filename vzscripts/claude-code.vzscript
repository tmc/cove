# claude-code — Install Claude Code CLI via the native installer
# runs-on: daemon

guest-ping
guest-shell install-claude-code.sh

-- install-claude-code.sh --
#!/bin/bash
set -eu

BREW_USER=$(dscl . -read /Groups/admin GroupMembership | tr ' ' '\n' | grep -v -E '^(GroupMembership:|root|_)' | head -1)
if [ -z "$BREW_USER" ]; then
  echo "error: no admin user found" >&2
  exit 1
fi
echo "Installing Claude Code as user: $BREW_USER"

su -l "$BREW_USER" -c 'curl -fsSL https://claude.ai/install.sh | bash'

INSTALLED=$(su -l "$BREW_USER" -c '$HOME/.local/bin/claude --version')
echo "Installed: claude $INSTALLED"

# Ensure ~/.local/bin is on PATH for future interactive shells.
su -l "$BREW_USER" -c '
  grep -q ".local/bin" ~/.zshrc 2>/dev/null || echo '\''export PATH="$HOME/.local/bin:$PATH"'\'' >> ~/.zshrc
'
