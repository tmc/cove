# developer-tools — Install Xcode Command Line Tools

guest-ping
guest-write /etc/profile.d/developer.sh developer.sh
guest-shell install-clt.sh

-- developer.sh --
# Added by vzscript: developer-tools
export DEVELOPER_DIR=/Library/Developer/CommandLineTools

-- install-clt.sh --
#!/bin/bash
set -e
xcode-select --install 2>/dev/null || true
echo "Waiting for Xcode Command Line Tools..."
until xcode-select -p &>/dev/null; do
  sleep 5
done
echo "Xcode CLT installed: $(xcode-select -p)"
