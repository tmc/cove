{
  "id": "finder-create-folder",
  "image": "macos-base:v1",
  "domain": "Finder",
  "instruction": "Using Finder, create a new folder named {FOLDER} on the Desktop.",
  "source": "cove-original (design 047 §9 slice 4); Tier-A file_exists",
  "complexity": 2,
  "subset": ["test_small"],
  "schema": [
    {"name": "FOLDER", "pool": ["Project", "Invoices", "Photos", "Drafts", "Archive"]}
  ],
  "config": [
    {"args": ["sh", "-c", "rm -rf \"$HOME/Desktop/{FOLDER}\""]}
  ],
  "solution": [
    {"args": ["sh", "-c", "mkdir -p \"$HOME/Desktop/{FOLDER}\""]}
  ],
  "evaluator": {
    "func": "file_exists",
    "result": {
      "kind": "exec",
      "args": ["sh", "-c", "test -d \"$HOME/Desktop/{FOLDER}\" && echo true || echo false"]
    }
  }
}
