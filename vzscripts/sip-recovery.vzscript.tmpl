# sip-recovery - Recovery automation for SIP changes
# Auto-generated vzscript for SIP {{.Mode}} in recovery mode
# Generated by: cove sip {{.Mode}}-auto
{{- $command := printf "csrutil %s" .Mode -}}
{{- $success := "System Integrity Protection" -}}
{{- if eq .Mode "disable" -}}
{{- $success = "System Integrity Protection is off." -}}
{{- else if eq .Mode "enable" -}}
{{- $success = "System Integrity Protection is on." -}}
{{- end }}

label-push {{quote (printf "SIP %s" .Mode)}}
wait 20s
label-push 'Recovery picker'
recovery-options 180s
recovery-continue 240s
wait-menu-text Utilities 180s
label-pop
label-push 'Recovery Terminal'
key cmd+shift+t
ocr-wait '-bash-3.2#' 60s
key cmd+k
wait 500ms
type-keycodes {{quote $command}}
key return
wait 2s
label-pop
label-push 'csrutil prompts'
{{ if .Confirm }}
answer-visible -timeout 45s -progress 'Authorized user' -progress 'Enter username' -progress 'user name' -progress 'Password' -progress 'Enter password' -progress 'password for user' -progress {{quote $success}} 'y/n' 'y' 'Are you sure' 'y' 'security level to full boot security' 'y'
wait 1s
{{ end }}
{{ if .Username }}
answer-visible -optional -timeout 5s -progress 'Password' -progress 'Enter password' -progress 'password for user' -progress {{quote $success}} 'Authorized user' {{quote .Username}} 'Enter username' {{quote .Username}} 'user name' {{quote .Username}}
wait 1s
{{ end }}
{{ if .Password }}
answer-visible -timeout 45s -progress {{quote $success}} -progress '-bash-3.2#' 'Password' {{quote .Password}} 'Enter password' {{quote .Password}} 'password for user' {{quote .Password}}
wait 2s
{{ end }}
ocr-wait {{quote $success}} 60s
[text-visible:{{queryescape $success}}] screenshot
label-pop
{{ if .Reboot }}
label-push 'Reboot'
[text-visible:{{queryescape $success}}] type-keycodes 'reboot'
[text-visible:{{queryescape $success}}] key return
wait 2s
label-pop
{{ end }}
label-pop
